import requests
import csv

def reconstruct_abstract(inverted_index):
    if not inverted_index:
        return ""
    positions = {}
    for word, pos_list in inverted_index.items():
        for pos in pos_list:
            positions[pos] = word
    return " ".join(positions[i] for i in sorted(positions))

journals = {
    "israeli_affairs": "S106532728",
    "palestine_studies": "S88529193"
}

rows = []

for name, source_id in journals.items():
    r = requests.get("https://api.openalex.org/works", params={
        "filter": f"primary_location.source.id:{source_id},publication_year:2000-2024",
        "search": "economy OR economic OR GDP OR trade OR labor OR development OR poverty OR Palestine OR \"paris protocol\"",
        "per_page": 200,
        "mailto": "your@email.com"
    })
    data = r.json()

    for work in data['results']:
        rows.append({
            "journal": name,
            "title": work['title'],
            "year": work['publication_year'],
            "abstract": reconstruct_abstract(work.get('abstract_inverted_index')),
            "concepts": ", ".join([c['display_name'] for c in work['concepts'][:5]]),
            "doi": work['doi']
        })

with open("literature_review.csv", "w", newline="", encoding="utf-8") as f:
    writer = csv.DictWriter(f, fieldnames=["journal", "title", "year", "abstract", "concepts", "doi"])
    writer.writeheader()
    writer.writerows(rows)

print(f"Done. {len(rows)} papers saved to literature_review.csv")
